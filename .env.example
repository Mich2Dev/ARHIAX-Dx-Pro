# ── ARHIAX Dx — Variables de entorno ────────────────────────────────────────
# Copia este archivo a .env y completa los valores antes de levantar el sistema.
# Para desarrollo local: docker compose up --build
# Para producción:       docker compose -f docker-compose.prod.yml up -d

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=arhiax
POSTGRES_PASSWORD=arhiax
POSTGRES_DB=arhiax_dx

# ── Redis ────────────────────────────────────────────────────────────────────
# Dejar vacío en desarrollo. En producción usar una contraseña fuerte.
REDIS_PASSWORD=

# ── URLs públicas ────────────────────────────────────────────────────────────
# URL donde corre el frontend (usada para generar links de encuesta)
APP_URL=http://localhost:3000
# URL donde corre el pipeline API (usada por el frontend)
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000

# ── LLM Providers ────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Dx Pro Integration ───────────────────────────────────────────────────────
# URL del servicio Dx Pro (en Docker: http://dxpro:8310, local: http://localhost:8310)
DXPRO_URL=http://dxpro:8310

# ── Seguridad ────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Usuario admin inicial (seed) ─────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@arhiax.com
SEED_ADMIN_PASSWORD=arhiax-admin-2026
SEED_ADMIN_NAME=Admin ARHIAX

# ── Notificaciones (opcional) ────────────────────────────────────────────────
HIC_WEBHOOK_URL=
WHATSAPP_BUSINESS_WEBHOOK=
